# API Keys
OPENAI_API_KEY=

# Set log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable JSON output for production (default: false for development)
JSON_LOGS=false

# Path to the log file (default: logs/app.log)
LOG_FILE_PATH=logs/app.log

# Set to 'true' to enable file logging (default: false)
ENABLE_FILE_LOGGING: true
